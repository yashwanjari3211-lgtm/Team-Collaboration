# ========================================== #
# ENVIRONMENT VARIABLES TEMPLATE             #
# ========================================== #
# INSTRUCTIONS: 
# 1. Copy this file and rename the copy to strictly '.env' (with the dot in front)
# 2. Replace the placeholder values below with your actual secret data.
# 3. NEVER commit the real '.env' file to GitHub!

# --- PostgreSQL Database Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_super_secret_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=saas_db

# --- Redis Configuration (For WebSockets & Caching) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT Authentication Security ---
# To generate a random secret key, open your terminal and type: openssl rand -hex 32
SECRET_KEY=replace_this_with_a_long_random_string_of_characters
ALGORITHM=HS256
# 10080 minutes = 7 days. This is how long a user stays logged in.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Google OAuth 2.0 ---
# Get these from: https://console.cloud.google.com/ > APIs & Services > Credentials
GOOGLE_CLIENT_ID=718401404384-ge9khsrgj1t2g2mgm7qu1ig400n78ihi.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# --- Application Settings ---
# Comma-separated list of allowed frontend URLs that can talk to this backend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

